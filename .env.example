# Neon serverless Postgres (https://neon.tech)
# Use the pooled connection string for serverless / edge runtimes
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Photo URL — defaults to the GitHub raw URL.
# When you upload to Cloudflare R2, replace with the public R2 URL.
# This is only the *fallback*; the photo URL stored in the DB via /admin takes precedence.
NEXT_PUBLIC_PHOTO_URL=https://raw.githubusercontent.com/eeya7ya/yahya.me/main/ChatGPT%20Image%20May%208%2C%202026%2C%2007_03_21%20PM.png

# Admin panel (/admin) credentials.
# ADMIN_PASSWORD: required to sign in. Pick a long random string.
# ADMIN_SECRET: optional separate secret used to sign session cookies. If unset
# the session cookie is signed with ADMIN_PASSWORD, which means rotating the
# password also invalidates open sessions.
ADMIN_PASSWORD=change-me
ADMIN_SECRET=

# Cloudflare R2 — used by the /admin photo uploader.
# Leave empty to disable in-admin uploads (you can still paste any HTTPS URL).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the bucket. Either the r2.dev URL Cloudflare gives you
# when you enable public access (https://pub-xxxxx.r2.dev) or a custom domain
# (https://photos.yahya.me). No trailing slash.
R2_PUBLIC_URL=
